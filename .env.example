# ─────────────────────────────────────────────────────────────────
# Dyscalculia Detection System — Environment Variables
# Copy this to .env for local development (never commit .env to git)
# In Render: add these under Environment → Environment Variables
# ─────────────────────────────────────────────────────────────────

# Supabase PostgreSQL connection string
# Get from: Supabase Dashboard → Project Settings → Database → URI
# Use the "Transaction pooler" (port 6543) for Render / serverless
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# Flask secret key — any long random string
SECRET_KEY=dyscalculia_secret_2026
